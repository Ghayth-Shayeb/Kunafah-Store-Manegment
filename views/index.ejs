    <link rel="shortcut icon" href="IMG/AboAnasSweets.png" type="image.png">
    <title>حلويات أبو أنس</title>
</head>
<body>
<!-- NavBar section -->
<nav class="navbar navbar-expand-lg bg-body-tertiary">
  <div class="container-fluid">
    <img src="IMG/AboAnasSweets.png" alt="Abo Abas" id="perfectCircle">
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavDropdown">
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link" href="#about-store">عن المحل و ماذا نقدم</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#products">الأسعار</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#order-now">اطلب الآن</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#edit">تعديل بيانات طلبك</a>
        </li>
        </li>
      </ul>
    </div>
  </div>
</nav>

 <!-- About Store section -->
    <br>
    <div class="about-store" id="about-store" style="margin-top: 100px;">
        <h1>عن المحل</h1>
        <p>محل أبو أنس يقع في قرية إجنسنيا\نابلس لصاحبه أبو أنس, يتميز المحل بالكنافة الخشنة (البرمة), والكلاج والفطير وغيرها في رمضان خصوصاَ.</p>
        <hr>
        <h1>ماذا نقدم</h1>
        <p>في الأيام العادية: الكنافة (البرمة فقط)</p>
        <p>في رمضان: الكلاج, الفطير, البقلاوة, الهريسة</p>
    </div>

<!-- Products Prices -->
    <br>
<!-- Products Prices -->

<div class="about-store">
    <h1>الأسعار</h1>

<div class="products" id="products">

    <div class="product-card">
        <h3>الكنافة</h3>
        <p>25 شيكل / كيلو</p>
    </div>

    <div class="product-card">
        <h3>البقلاوة</h3>
        <p>25 شيكل / كيلو</p>
    </div>

    <div class="product-card">
        <h3>الكلاج</h3>
        <p>25 شيكل / كيلو</p>
    </div>

    <div class="product-card">
        <h3>الفطير</h3>
        <p>25 شيكل / كيلو</p>
    </div>

    <div class="product-card">
        <h3>الهريسة</h3>
        <p>16 شيكل / كيلو</p>
    </div>

</div>

</div>

<!-- Form -->
    <br>
<form action="/sign" method="POST" class="requesting-form" id="order-now">
    <h1>اطلب الآن</h1>
    <h2>املأ الحقول:</h2>

<div class="form-group">
    <label for="input1">الشهر</label>
    <input id="input1" type="number" name="month" placeholder="اكتب رقم الشهر." min="1" max="12" required>
</div>

<div class="form-group">
    <label for="input2">اليوم للشهر</label>
    <input id="input2" type="number" name="dayOfMonth" min="1" max="31" placeholder="يوم 20 من الشهر كمثال." required>
</div>

<div class="form-group">
    <label for="input3">الساعة</label>
    <input id="input3" type="time" name="time" placeholder="اضغط على أيقونة الساعة." style="text-align: right;" required>
</div>

<div class="form-group">
    <label for="input4">كم كيلو؟</label>
    <input id="input4" type="text" name="quantity" min="1" placeholder="اضف رقماَ." required>
</div>

<div class="form-group">
    <label for="input5">ملاحظات إضافية</label>
    <textarea id="input5" rows="4" name="additionalNotes" placeholder="كيف تريد طلبك؟مثال: هل هنالك احد من العائلة لديه مرض السكري ؟ يمكننا تخصيص كمية له. "></textarea>
</div>

<div class="form-group">
    <label for="input6">الاسم</label>
    <input id="input6" type="text" name="yourName" placeholder="اسمك." required>
</div>

<div class="form-group">
    <label for="input7">رقم الهاتف</label>
    <input id="input7" type="number" name="yourPhone" placeholder="رقم هاتفك لنتواصل معك." style="text-align: right;" required>
</div>
<button type="submit" class="submit-btn">إرسال الطلب</button>

</form>

<form action="/find" method="POST" class="requesting-form" id="edit">
    <h1>هل تود التعديل على بياناتك ؟</h1>
<div class="form-group">
    <label for="input8">رقم الهاتف</label>
    <input id="input8" type="number" name="yourPhone" placeholder="رقم هاتفك لتعديل البينات." style="text-align: right;">
</div>

    <button type="submit" class="submit-btn">تعديل</button>
</form>


<footer>
    <h1>Contact | تواصل</h1>
    <p><strong>0569131166 || 0599187319</strong></p>
</footer>
        <style>
            @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap');

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Cairo',sans-serif;
background:linear-gradient(135deg,#f7d774,#d9a404);
min-height:100vh;
direction:rtl;
}

nav{
width:90%;
background:rgba(255,255,255,0.9);
backdrop-filter:blur(10px);
border-bottom-left-radius: 20px;
border-bottom-right-radius: 20px;
box-shadow:0 10px 25px rgba(0,0,0,0.15);
padding:10px 20px;
position: sticky;
top: 0;
z-index: 999;
}
nav.navbar{
position: fixed;
top: 0;
left: 0;
width: 100%;
z-index: 1050;
box-shadow: 0 4px 15px rgba(0,0,0,0.2);
}

#perfectCircle{
width:70px;
height:70px;
object-fit:cover;
border-radius:50%;
border:4px solid #d9a404;
}

.nav-link{
font-weight:700;
color:#222 !important;
transition:.3s;
}

.nav-link:hover{
color:#d9a404 !important;
}

.about-store,
.requesting-form{
width:min(900px,90%);
margin:30px auto;
background:white;
padding:30px;
border-radius:20px;
box-shadow:0 10px 30px rgba(0,0,0,.12);
}

h1{
text-align:center;
margin-bottom:20px;
font-weight:800;
color:#d9a404;
}

p{
font-size:1.05rem;
line-height:2;
}

table{
width:100%;
border-collapse:collapse;
overflow:hidden;
border-radius:12px;
}

th{
background:#d9a404;
color:white;
padding:15px;
}

td{
padding:12px;
text-align:center;
}

tr:nth-child(even){
background:#f8f8f8;
}

table,th,td{
border:none;
}

.requesting-form{
text-align:right;
}

button{
background:#d9a404;
border:none;
color:white;
padding:12px 25px;
border-radius:10px;
font-weight:bold;
cursor:pointer;
transition:.3s;
}

button:hover{
transform:translateY(-2px);
}
.products{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
gap:20px;
margin-top:20px;
}

.product-card{
background:#fff;
border-radius:15px;
padding:20px;
text-align:center;
box-shadow:0 5px 15px rgba(0,0,0,0.12);
transition:0.3s;
border:2px solid #f0c040;
}

.product-card:hover{
transform:translateY(-5px);
}

.product-card h3{
color:#b8860b;
font-weight:bold;
margin-bottom:10px;
}

.product-card p{
font-size:1.1rem;
font-weight:bold;
margin:0;
}
.requesting-form{
max-width:700px;
margin:30px auto;
background:white;
padding:30px;
border-radius:20px;
box-shadow:0 10px 30px rgba(0,0,0,.12);
}

.requesting-form h1{
color:#b8860b;
}

.requesting-form h2{
text-align:center;
font-size:1rem;
color:#666;
margin-bottom:25px;
}

footer{
width:min(900px,100%);
margin: auto;
background:white;
padding:10px;
position: relative;
border-top-left-radius:20px;
border-top-right-radius: 20px;
box-shadow:0 10px 30px rgba(0,0,0,.12);
bottom: 0;
text-align: center;
justify-content: center;

}


.form-group{
display:flex;
flex-direction:column;
margin-bottom:18px;
}

.form-group label{
font-weight:bold;
margin-bottom:8px;
}

.form-group input,
.form-group textarea{
padding:12px;
border:2px solid #ddd;
border-radius:10px;
font-family:"Cairo";
font-size:1rem;
transition:.3s;
}

.form-group input:focus,
.form-group textarea:focus{
outline:none;
border-color:#d4a017;
box-shadow:0 0 10px rgba(212,160,23,.3);
}

.submit-btn{
width:100%;
padding:14px;
border:none;
border-radius:10px;
background:#d4a017;
color:white;
font-size:1.1rem;
font-weight:bold;
cursor:pointer;
transition:.3s;
}

.submit-btn:hover{
transform:translateY(-2px);
}

        </style>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>