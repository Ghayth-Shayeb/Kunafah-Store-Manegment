<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="/public/IMG/AboAnasSweets.png" type="image.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <title>تعديل المعلومات</title>

    <style>
@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap');

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Cairo',sans-serif;
    background:linear-gradient(135deg,#f7d774,#d9a404);
    min-height:100vh;
    padding:40px 20px;
    direction:rtl;
}

.orders-container{
    max-width:700px;
    margin:auto;
}

.order-card{
    background:white;
    border-radius:20px;
    padding:25px;
    border:3px solid #f0c040;
    box-shadow:0 10px 25px rgba(0,0,0,.12);
    transition:.3s;
}

.order-card:hover{
    transform:translateY(-5px);
}

.order-card h2{
    color:#b8860b;
    margin-bottom:20px;
    font-weight:800;
    border-bottom:2px solid #eee;
    padding-bottom:10px;
    text-align:center;
}

input{
    width:100%;
    padding:12px;
    margin:10px 0;
    border:2px solid #ddd;
    border-radius:10px;
    font-family:'Cairo';
    font-size:1rem;
    transition:.3s;
}

input:focus{
    outline:none;
    border-color:#d4a017;
    box-shadow:0 0 10px rgba(212,160,23,.3);
}

button{
    width:100%;
    padding:14px;
    border:none;
    border-radius:10px;
    background:#d4a017;
    color:white;
    font-size:1.1rem;
    font-weight:bold;
    cursor:pointer;
    transition:.3s;
    margin-top:10px;
}

button:hover{
    transform:translateY(-2px);
}
    </style>
</head>

<body>

<div class="orders-container">

    <div class="order-card">

        <h2>تعديل الطلب</h2>
<% items.forEach(item => { %>

<form action="/update/<%= item._id %>?_method=PUT" method="POST">
    <input name="yourName" value="<%= item.yourName %>" placeholder="الاسم">
    <input name="yourPhone" value="<%= item.yourPhone %>" placeholder="رقم الهاتف">
    <input name="time" value="<%= item.time %>" type="time">
    <input name="quantity" value="<%= item.quantity %>" type="number" placeholder="الكمية">
    <input name="additionalNotes" value="<%= item.additionalNotes %>" placeholder="ملاحظات">

    <button type="submit">حفظ</button>
</form>

<% }) %>
    </div>

</div>

</body>
</html>