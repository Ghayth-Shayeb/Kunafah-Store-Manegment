<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="/IMG/AboAnasSweets.png" type="image/x-icon">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <title>Dashboard</title>
</head>
<body>
<div class="orders-container">

<% items.forEach(item => { %>

<div class="order-card">

    <h2><%= item.yourName %></h2>

    <div class="info">
        <p><strong>📞 الهاتف:</strong> <%= item.yourPhone %></p>
        <p><strong>🕒 الوقت:</strong> <%= item.time ? from24to12(item.time) : "غير محدد" %></p>
        <p><strong>📅 التاريخ:</strong>
            <br>
            <%= item.dayOfMonth %>-->اليوم
            <br>
            <%= item.month %>-->الشهر
        </p>
        <p><strong>⚖️ الكمية:</strong> <%= item.quantity %> كيلو</p>
    </div>
    <div class="notes">
        <strong>📝 ملاحظات:</strong>
        <p><%= (item.additionalNotes !== "" && item.additionalNotes !== "يمكنك تركه فارغاً في حال عدم وجود ملاحظات.") ? item.additionalNotes : "لا توجد ملاحظات" %></p>
    </div>
    <form action="/delete/<%= item._id %>" method="POST">
        <p style="margin-top: 10px;">هل انهيت الطلب ؟</p>
        <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i></button>
    </form>
    <form action="/confirm-order" method="POST">
    <input type="hidden" name="yourName" value="<%= item.yourName %>">
    <input type="hidden" name="yourPhone" value="<%= item.yourPhone %>">
    <input type="hidden" name="quantity" value="<%= item.quantity %>">
    <input type="hidden" name="time" value="<%= item.time %>">

    <button type="submit" class="btn btn-success" style="margin-top:10px;">🤖 تأكيد ذكي + مكالمة</button>
</form>
</div>

<% }) %>

</div>

<style>
@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap');

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Cairo',sans-serif;
    background:linear-gradient(135deg,#f7d774,#d9a404);
    min-height:100vh;
    padding:40px 20px;
    direction:rtl;
}

.orders-container{
    max-width:1200px;
    margin:auto;

    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(350px,1fr));
    gap:25px;
}

.order-card{
    background:white;
    border-radius:20px;
    padding:25px;

    border:3px solid #f0c040;

    box-shadow:
        0 10px 25px rgba(0,0,0,.12);

    transition:.3s;
}

.order-card:hover{
    transform:translateY(-5px);
}

.order-card h2{
    color:#b8860b;
    margin-bottom:15px;
    font-weight:800;

    border-bottom:2px solid #eee;
    padding-bottom:10px;
}

.info p{
    margin:10px 0;
    font-size:1rem;
}

.notes{
    margin-top:15px;
    background:#fff9e8;
    border-radius:12px;
    padding:12px;
}

.notes p{
    margin-top:8px;
    color:#555;
}

strong{
    color:#b8860b;
}
</style>
    <script src="/javascript/time.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>